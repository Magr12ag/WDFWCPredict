", "away": "Winner match 98", "group": "Knockout", "venue": "Dallas Stadium", "round": "Semi-final", "homeScore": null, "awayScore": null, "status": "Scheduled"}, {"n": 102, "date": "July 15", "time": "Match 102", "home": "Winner match 99", "away": "Winner match 100", "group": "Knockout", "venue": "Atlanta Stadium", "round": "Semi-final", "homeScore": null, "awayScore": null, "status": "Scheduled"}, {"n": 103, "date": "July 18", "time": "Match 103", "home": "Runner-up match 101", "away": "Runner-up match 102", "group": "Knockout", "venue": "Miami Stadium", "round": "Bronze final", "homeScore": null, "awayScore": null, "status": "Scheduled"}, {"n": 104, "date": "July 19", "time": "Match 104", "home": "Winner match 101", "away": "Winner match 102", "group": "Knockout", "venue": "New York New Jersey Stadium", "round": "Final", "homeScore": null, "awayScore": null, "status": "Scheduled"}], "flags": {"Mexico": "🇲🇽", "South Africa": "🇿🇦", "Korea Republic": "🇰🇷", "Czechia": "🇨🇿", "Canada": "🇨🇦", "Bosnia and Herzegovina": "🇧🇦", "Qatar": "🇶🇦", "Switzerland": "🇨🇭", "USA": "🇺🇸", "Paraguay": "🇵🇾", "Brazil": "🇧🇷", "Morocco": "🇲🇦", "Haiti": "🇭🇹", "Scotland": "🏴", "Australia": "🇦🇺", "Türkiye": "🇹🇷", "Germany": "🇩🇪", "Curaçao": "🇨🇼", "Ivory Coast": "🇨🇮", "Ecuador": "🇪🇨", "Netherlands": "🇳🇱", "Japan": "🇯🇵", "Sweden": "🇸🇪", "Tunisia": "🇹🇳", "Spain": "🇪🇸", "Cabo Verde": "🇨🇻", "Belgium": "🇧🇪", "Egypt": "🇪🇬", "Saudi Arabia": "🇸🇦", "Uruguay": "🇺🇾", "IR Iran": "🇮🇷", "Iran": "🇮🇷", "New Zealand": "🇳🇿", "France": "🇫🇷", "Senegal": "🇸🇳", "Iraq": "🇮🇶", "Norway": "🇳🇴", "Argentina": "🇦🇷", "Algeria": "🇩🇿", "Austria": "🇦🇹", "Jordan": "🇯🇴", "England": "🏴", "Croatia": "🇭🇷", "Ghana": "🇬🇭", "Panama": "🇵🇦", "Portugal": "🇵🇹", "Uzbekistan": "🇺🇿", "Colombia": "🇨🇴", "DR Congo": "🇨🇩", "Congo DR": "🇨🇩", "South Korea": "🇰🇷", "Cape Verde": "🇨🇻", "Bosnia": "🇧🇦"}};
const API_URL = ""; // Optional: add results endpoint returning: [{n, homeScore, awayScore, status}]
const avatarIcons = ["🦁","🦊","🐼","🐯","🦅","🐙","🦄","🐝","🐳","🦋","🐢","🐲","🐺","🦉","🐬","🐘","🦒","🐧","🦜","🦖","🐨","🐻","🦥","🦦","🦩","🐿️","🦔","⭐"];

function flag(team) {
  return '<span class="flag">' + (DATA.flags[team] || "🏳️") + '</span>';
}

function norm(team) {
  return String(team || "")
    .replace("Türkiye","Turkey")
    .replace("IR Iran","Iran")
    .replace("Congo DR","DR Congo")
    .replace("Cabo Verde","Cape Verde")
    .toLowerCase();
}

function getFixtures() {
  try {
    return JSON.parse(localStorage.getItem("wdfFixtures")) || DATA.fixtures;
  } catch (e) {
    return DATA.fixtures;
  }
}

function saveFixtures(fixtures) {
  localStorage.setItem("wdfFixtures", JSON.stringify(fixtures));
}

function scorePerson(person, fixtures) {
  let pts = 0, wins = 0, draws = 0;
  for (const match of fixtures) {
    if (match.homeScore === null || match.awayScore === null) continue;
    for (const pick of person.teams) {
      const pickedHome = norm(pick) === norm(match.home);
      const pickedAway = norm(pick) === norm(match.away);
      if (!pickedHome && !pickedAway) continue;
      if (Number(match.homeScore) === Number(match.awayScore)) {
        pts += 1; draws += 1;
      } else if ((pickedHome && Number(match.homeScore) > Number(match.awayScore)) ||
                 (pickedAway && Number(match.awayScore) > Number(match.homeScore))) {
        pts += 3; wins += 1;
      }
    }
  }
  return {...person, pts, wins, draws};
}

function ranked() {
  const fixtures = getFixtures();
  return DATA.predictions
    .map(p => scorePerson(p, fixtures))
    .sort((a,b) => b.pts - a.pts || b.wins - a.wins || a.name.localeCompare(b.name));
}

function renderPodium() {
  const r = ranked();
  const hasScores = r.some(p => p.pts > 0);
  const el = document.getElementById("podium");
  if (!hasScores) {
    el.innerHTML = '<div class="pod" style="grid-column:1/-1;background:rgba(255,255,255,.08)"><h3>🏁 Podium opens after the first completed match</h3><p class="muted">Everyone starts at 0 points. Gold, silver and bronze will appear automatically once scores are entered or refreshed.</p></div>';
    return;
  }
  const podiumOrder = [
    {person:r[1], cls:"silver", medal:"🥈"},
    {person:r[0], cls:"gold", medal:"🥇"},
    {person:r[2], cls:"bronze", medal:"🥉"}
  ].filter(x => x.person);
  el.innerHTML = podiumOrder.map(x => {
    const idx = DATA.predictions.findIndex(p => p.name === x.person.name);
    const picks = x.person.teams.map(t => '<span class="pill">' + flag(t) + t + '</span>').join("") || '<span class="muted">No picks yet</span>';
    return '<div class="pod ' + x.cls + '"><div class="avatar">' + avatarIcons[idx] + '</div><h3>' + x.medal + ' ' + x.person.name + '</h3><b style="font-size:34px">' + x.person.pts + '</b><div>' + picks + '</div></div>';
  }).join("");
}

function renderLeaderboard() {
  const rows = ranked().map((p, i) => {
    const idx = DATA.predictions.findIndex(x => x.name === p.name);
    const picks = p.teams.map(t => '<span class="pill">' + flag(t) + t + '</span>').join("") || '<span class="muted">No picks</span>';
    return '<tr><td class="rank">' + (i+1) + '</td><td><span class="avatar">' + avatarIcons[idx] + '</span> <b>' + p.name + '</b></td><td>' + picks + '</td><td><b>' + p.pts + '</b></td><td>' + p.wins + '</td><td>' + p.draws + '</td></tr>';
  }).join("");
  document.getElementById("leaderboard").innerHTML = '<table><tr><th>#</th><th>Colleague</th><th>Predictions</th><th>Pts</th><th>Wins</th><th>Draws</th></tr>' + rows + '</table>';
}

function matchRow(match) {
  const hs = match.homeScore === null ? "" : match.homeScore;
  const as = match.awayScore === null ? "" : match.awayScore;
  return '<div class="match" style="padding:10px;border-bottom:1px solid rgba(255,255,255,.1)">' +
    '<b>#' + match.n + '</b>' +
    '<div>' + flag(match.home) + ' ' + match.home + '</div>' +
    '<div class="score"><input value="' + hs + '" onchange="setScore(' + match.n + ',\'homeScore\',this.value)"> - <input value="' + as + '" onchange="setScore(' + match.n + ',\'awayScore\',this.value)"></div>' +
    '<div>' + flag(match.away) + ' ' + match.away + '</div>' +
    '<div><b>' + match.date + '</b> ' + (match.time || "") + '<br><span class="muted">' + match.round + ' • ' + match.venue + '</span></div>' +
  '</div>';
}

function renderMatches() {
  const q = (document.getElementById("filter").value || "").toLowerCase();
  const rf = document.getElementById("roundFilter").value || "";
  const fixtures = getFixtures().filter(m => (!rf || m.round === rf) && JSON.stringify(m).toLowerCase().includes(q));
  const first = fixtures.slice(0, 5);
  const rest = fixtures.slice(5);
  let output = '<h3>Upcoming 5 games</h3>' + first.map(matchRow).join("");
  for (let i=0; i<rest.length; i+=10) {
    const batch = rest.slice(i, i+10);
    if (!batch.length) continue;
    output += '<details class="details-batch"><summary>Show next ' + batch.length + ' games — matches #' + batch[0].n + '–#' + batch[batch.length-1].n + '</summary>' + batch.map(matchRow).join("") + '</details>';
  }
  document.getElementById("matches").innerHTML = output || '<p class="muted">No matches found.</p>';
}

function setScore(matchNumber, key, value) {
  const fixtures = getFixtures();
  const match = fixtures.find(m => Number(m.n) === Number(matchNumber));
  if (!match) return;
  match[key] = value === "" ? null : Number(value);
  match.status = (match.homeScore !== null && match.awayScore !== null) ? "Final" : "Scheduled";
  saveFixtures(fixtures);
  renderAll();
}

function renderChart() {
  const counts = {};
  DATA.predictions.flatMap(p => p.teams).forEach(t => counts[t] = (counts[t] || 0) + 1);
  const items = Object.entries(counts).sort((a,b) => b[1]-a[1]).slice(0,12);
  const c = document.getElementById("chart");
  const ctx = c.getContext("2d");
  ctx.clearRect(0,0,c.width,c.height);
  const max = Math.max(1, ...items.map(x => x[1]));
  items.forEach((item, i) => {
    const y = 28 + i*23;
    const width = item[1] / max * 620;
    ctx.fillStyle = ["#06d6a0","#118ab2","#ef476f","#ffd166"][i % 4];
    ctx.fillRect(210, y, width, 15);
    ctx.fillStyle = "#f5fbff";
    ctx.font = "15px Arial";
    ctx.fillText((DATA.flags[item[0]] || "🏳️") + " " + item[0], 10, y + 13);
    ctx.fillText(item[1], 220 + width, y + 13);
  });
}

async function refreshResults() {
  if (!API_URL) {
    alert("No results API is configured yet. Manual score entry is active in the match roster.");
    return;
  }
  try {
    const res = await fetch(API_URL);
    const incoming = await res.json();
    const fixtures = getFixtures();
    incoming.forEach(r => {
      const match = fixtures.find(m => Number(m.n) === Number(r.n));
      if (match) {
        match.homeScore = r.homeScore;
        match.awayScore = r.awayScore;
        match.status = r.status || match.status;
      }
    });
    saveFixtures(fixtures);
    renderAll();
  } catch (e) {
    alert("Result refresh failed: " + e.message);
  }
}

function resetScores() {
  localStorage.removeItem("wdfFixtures");
  renderAll();
}

function renderAll() {
  renderPodium();
  renderLeaderboard();
  renderMatches();
  renderChart();
}

document.addEventListener("DOMContentLoaded", renderAll);
</script>
</body>
</html>
