<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>WDF World Cup Predictions Dashboard</title>
<style>
:root {
  --bg:#07111f; --card:#10213f; --soft:#18315c; --txt:#f5fbff; --muted:#a8b8d8;
  --gold:#ffd166; --silver:#d7e1f1; --bronze:#df9b62; --green:#06d6a0; --pink:#ef476f; --blue:#118ab2;
}
* { box-sizing:border-box; }
body {
  margin:0; font-family:Inter,system-ui,Segoe UI,Arial,sans-serif;
  background:radial-gradient(circle at 10% 0%,#2256b6 0,#07111f 32%,#020617 100%);
  color:var(--txt);
}
header {
  padding:34px 22px; background:linear-gradient(135deg,#ef476f,#118ab2 55%,#06d6a0);
  position:relative; overflow:hidden;
}
header:after { content:"⚽ 🏆 ⚽"; position:absolute; right:22px; top:20px; font-size:64px; opacity:.22; }
h1 { margin:0; font-size:clamp(28px,5vw,56px); }
h2 { margin-top:0; }
.sub { opacity:.95; font-weight:700; }
.wrap { max-width:1280px; margin:auto; padding:18px; }
.grid { display:grid; grid-template-columns:repeat(12,1fr); gap:16px; }
.card {
  grid-column:span 12; background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,255,255,.035));
  border:1px solid rgba(255,255,255,.13); border-radius:24px; padding:18px;
  box-shadow:0 18px 60px rgba(0,0,0,.3); backdrop-filter:blur(8px);
}
.half { grid-column:span 6; }
@media(max-width:850px) { .half { grid-column:span 12; } }
.podium { display:grid; grid-template-columns:repeat(3,1fr); gap:12px; align-items:end; }
.pod { border-radius:22px; text-align:center; padding:18px; background:var(--soft); }
.pod.gold { background:linear-gradient(180deg,var(--gold),#b7791f); color:#1d1200; transform:translateY(-14px); }
.pod.silver { background:linear-gradient(180deg,var(--silver),#64748b); color:#06101f; }
.pod.bronze { background:linear-gradient(180deg,var(--bronze),#7c3f1d); }
.avatar {
  width:48px; height:48px; border-radius:50%; display:inline-grid; place-items:center;
  background:linear-gradient(135deg,#06d6a0,#118ab2,#ef476f); font-size:24px; border:3px solid rgba(255,255,255,.7);
}
table { width:100%; border-collapse:collapse; }
th,td { padding:10px; border-bottom:1px solid rgba(255,255,255,.1); text-align:left; vertical-align:top; }
th { color:#c7d5ef; font-size:12px; text-transform:uppercase; letter-spacing:.06em; }
tr:hover { background:rgba(255,255,255,.05); }
.pill {
  display:inline-flex; gap:5px; align-items:center; border-radius:999px; padding:5px 9px; margin:2px;
  background:rgba(255,255,255,.1); border:1px solid rgba(255,255,255,.12); white-space:nowrap;
}
.flag { font-size:21px; line-height:1; display:inline-block; min-width:24px; text-align:center; }
.rank { font-weight:900; font-size:18px; }
input,select,button { border:0; border-radius:12px; padding:10px 12px; }
button { background:#06d6a0; font-weight:900; color:#032019; cursor:pointer; }
.danger { background:#ef476f; color:white; }
.toolbar { display:flex; gap:10px; flex-wrap:wrap; margin:8px 0 16px; }
.match { display:grid; grid-template-columns:56px 1fr 92px 1fr 160px; gap:8px; align-items:center; }
@media(max-width:650px) { .match { grid-template-columns:1fr; } }
.score { font-weight:900; text-align:center; background:#07111f; border-radius:12px; padding:8px; }
.score input { width:36px; padding:6px; text-align:center; }
.muted { color:var(--muted); }
canvas { width:100%; height:260px; background:rgba(255,255,255,.04); border-radius:16px; }
.note { font-size:12px; color:#b6c7e6; }
.details-batch { margin-top:10px; border:1px solid rgba(255,255,255,.12); border-radius:16px; overflow:hidden; }
.details-batch summary { cursor:pointer; padding:12px 14px; background:rgba(255,255,255,.08); font-weight:900; }
.details-batch[open] summary { background:rgba(6,214,160,.18); }
.status { display:inline-block; padding:4px 8px; border-radius:999px; background:rgba(255,255,255,.1); color:#c7d5ef; font-size:12px; }
</style>
</head>
<body>
<header>
  <h1>🏆 WDF World Cup Predictions</h1>
  <div class="sub">Automatic leaderboard • 104-match roster • country flags • avatars • charts • daily refresh-ready</div>
</header>

<div class="wrap">
  <div class="grid">
    <section class="card">
      <h2>🥇 Gold / Silver / Bronze Podium</h2>
      <div id="podium" class="podium"></div>
    </section>

    <section class="card half">
      <h2>🏅 Leaderboard</h2>
      <div class="toolbar">
        <button onclick="refreshResults()">🔄 Refresh results</button>
        <button class="danger" onclick="resetScores()">Reset local scores</button>
      </div>
      <div id="leaderboard"></div>
      <p class="note">Scoring: predicted team win = 3 pts, draw = 1 pt, loss/not played = 0. Scores can be entered manually in the match roster. A results API can be connected in the script.</p>
    </section>

    <section class="card half">
      <h2>📊 Prediction Statistics</h2>
      <canvas id="chart" width="900" height="320"></canvas>
    </section>

    <section class="card">
      <h2>📅 Match Roster — Upcoming 5 + expandable batches</h2>
      <div class="toolbar">
        <input id="filter" placeholder="Filter team, round, venue..." oninput="renderMatches()">
        <select id="roundFilter" onchange="renderMatches()">
          <option value="">All rounds</option>
          <option>Group Stage</option>
          <option>R32</option>
          <option>Round of 16</option>
          <option>Quarter-final</option>
          <option>Semi-final</option>
          <option>Bronze final</option>
          <option>Final</option>
        </select>
      </div>
      <div id="matches"></div>
    </section>
  </div>
</div>

